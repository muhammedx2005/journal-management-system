<%- include('../partials/header') %>

<div class="dashboard-hero mb-4">
  <p class="dashboard-hero__eyebrow mb-2">Yazar Paneli</p>
  <h1 class="dashboard-hero__title mb-1">Hoş geldin, <%= user.name %></h1>
  <p class="mb-0 opacity-75"><%= journal.name %> için gönderdiğiniz makalelerin özeti.</p>
</div>

<div class="row g-3 mb-4">
  <div class="col-sm-6 col-lg-4">
    <div class="card stat-tile glass-card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <i class="bi bi-file-earmark-text fs-2 text-primary"></i>
        <div>
          <div class="stat-tile__value"><%= totalSubmissions %></div>
          <div class="text-muted small">Toplam Gönderilen Makale</div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="d-flex flex-wrap gap-2 mb-4">
      <a href="/author/papers/new" class="btn btn-cta"><i class="bi bi-plus-circle me-1"></i>Yeni Makale Yükle</a>
      <a href="/author/papers" class="btn btn-outline-secondary"><i class="bi bi-list-ul me-1"></i>Makalelerimi Görüntüle</a>
    </div>

    <div class="mb-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0"><i class="bi bi-clock-history me-2"></i>Son Aktiviteler</h2>
      </div>

      <% if (recentSubmissions.length === 0) { %>
        <div class="card glass-card">
          <div class="card-body text-center text-muted py-5">Henüz makale göndermediniz.</div>
        </div>
      <% } else { %>
        <div class="card glass-card">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Makale Kodu</th>
                  <th>Başlık</th>
                  <th>Durum</th>
                  <th>Tarih</th>
                </tr>
              </thead>
              <tbody>
                <% recentSubmissions.forEach(function (submission) { %>
                  <tr>
                    <td class="text-nowrap"><%= submission.paper_code %></td>
                    <td><%= submission.title %></td>
                    <td><span class="badge rounded-pill badge--<%= submission.status %>"><%= submission.statusLabel %></span></td>
                    <td class="text-nowrap small text-muted"><%= new Date(submission.created_at).toLocaleDateString("tr-TR") %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="col-lg-4">
    <%- include('../partials/profile-summary-card') %>
  </div>
</div>

<%- include('../partials/footer') %>
