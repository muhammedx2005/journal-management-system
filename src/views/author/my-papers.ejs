<%- include('../partials/header') %>

<div class="mb-4">
  <h1 class="h3 mb-1">Makalelerim</h1>
  <p class="text-muted"><%= journal.name %> dergisine yaptığınız başvuruların durumu.</p>
</div>

<% if (submissions.length === 0) { %>
  <div class="card">
    <div class="card-body text-center text-muted py-5">
      <i class="bi bi-inbox display-6 d-block mb-2"></i>
      Henüz makale gönderiminiz bulunmuyor.
    </div>
  </div>
<% } else { %>
  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Makale Kodu</th>
            <th>Başlık</th>
            <th>Gönderim Tarihi</th>
            <th>Durum</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% submissions.forEach(function (submission) { %>
            <tr>
              <td class="text-nowrap"><%= submission.paper_code %></td>
              <td><%= submission.title %></td>
              <td class="text-nowrap"><%= submission.created_at.toLocaleDateString('tr-TR') %></td>
              <td><span class="badge rounded-pill badge--<%= submission.status %>"><%= submission.statusLabel %></span></td>
              <td class="text-end">
                <a href="/files/<%= submission.id %>" class="btn btn-sm btn-outline-secondary" target="_blank">
                  <i class="bi bi-download me-1"></i>İndir
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>
