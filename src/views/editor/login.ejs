<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-12 col-md-7 col-lg-5">
    <div class="card">
      <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
          <i class="bi bi-briefcase display-6 text-primary"></i>
          <h1 class="h3 mt-2 mb-1">Editör Girişi</h1>
          <p class="text-muted small mb-0"><%= journal.name %> editör paneline giriş yapın.</p>
        </div>

        <% if (errorMessage) { %>
          <div class="alert alert-danger py-2"><%= errorMessage %></div>
        <% } %>

        <form action="/editor/login" method="POST">
          <div class="mb-3">
            <label class="form-label">E-posta</label>
            <input type="email" name="email" class="form-control" required />
          </div>
          <div class="mb-3">
            <label class="form-label">Şifre</label>
            <input type="password" name="password" class="form-control" required />
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right me-1"></i>Giriş Yap
          </button>
        </form>

        <p class="text-center text-muted small mt-4 mb-0">
          Editör hesabı olmayanlar sistem yöneticisine başvurmalıdır.
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
