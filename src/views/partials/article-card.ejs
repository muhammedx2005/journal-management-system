<%
  // "Son Yayınlanan Makaleler" karti - hem ana sayfada hem yayin arsivinde
  // (public/home.ejs, public/archive.ejs) kullanilir. Beklenen local: article
  // (submissionModel.findPublished() satiri - title, abstract, author_name/
  // surname, updated_at, id).
  var publishedDate = new Date(article.updated_at).toLocaleDateString("tr-TR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
%>
<div class="card article-card h-100">
  <div class="card-body d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
      <span class="badge rounded-pill badge--published">
        <i class="bi bi-globe me-1"></i>Yayınlandı
      </span>
      <span class="text-muted small text-nowrap">
        <i class="bi bi-calendar3 me-1"></i><%= publishedDate %>
      </span>
    </div>

    <h3 class="h6 mb-2">
      <a href="/articles/<%= article.id %>" class="article-card__title-link stretched-link text-decoration-none">
        <%= article.title %>
      </a>
    </h3>

    <p class="text-muted small mb-2">
      <i class="bi bi-person me-1"></i><%= article.author_name %> <%= article.author_surname %>
    </p>

    <p class="text-muted small article-card__abstract mb-3">
      <%= article.abstract %>
    </p>

    <div class="mt-auto">
      <a href="/files/<%= article.id %>" target="_blank" class="article-card__pdf-btn">
        <i class="bi bi-file-earmark-pdf"></i>PDF İncele / Oku
      </a>
    </div>
  </div>
</div>
