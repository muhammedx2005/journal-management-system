    </div>
  </main>

  <footer class="site-footer pt-5 pb-4 mt-auto">
    <div class="container">
      <div class="row g-4 pb-4">
        <div class="col-lg-4">
          <h3 class="h6 footer-heading mb-3 d-flex align-items-center gap-2">
            <span class="brand-mark brand-mark--sm d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-cpu-fill"></i>
            </span>
            <%= journal.name %>
          </h3>
          <p class="small mb-2">ISSN <%= journal.issn %></p>
          <% if (journal.tagline) { %><p class="small mb-3 footer-tagline"><%= journal.tagline %></p><% } %>
          <p class="small mb-1">
            <i class="bi bi-envelope me-1"></i>
            <a href="mailto:<%= journal.contact.generalEmail %>" class="link-footer"><%= journal.contact.generalEmail %></a>
          </p>
          <% if (journal.contact.phone) { %>
            <p class="small mb-0"><i class="bi bi-telephone me-1"></i><%= journal.contact.phone %></p>
          <% } %>
        </div>
        <div class="col-6 col-lg-4">
          <h3 class="h6 footer-heading mb-3">Hızlı Linkler</h3>
          <ul class="list-unstyled small d-grid gap-2 mb-0">
            <% (journal.navigation || []).forEach(function (item) { %>
              <li><a href="<%= item.path %>" class="link-footer"><%= item.label %></a></li>
            <% }) %>
          </ul>
        </div>
        <div class="col-6 col-lg-4">
          <h3 class="h6 footer-heading mb-3">Giriş</h3>
          <ul class="list-unstyled small d-grid gap-2 mb-0">
            <li><a href="/author/login" class="link-footer">Yazar Girişi</a></li>
            <li><a href="/reviewer/login" class="link-footer">Hakem Girişi</a></li>
            <li><a href="/editor/login" class="link-footer">Editör Girişi</a></li>
          </ul>
        </div>
      </div>

      <hr class="footer-divider" />

      <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 small text-center text-md-start pt-2">
        <div>&copy; <%= new Date().getFullYear() %> <%= journal.name %> (<%= journal.shortName %>). Tüm hakları saklıdır.</div>
        <div>
          Baş Editör: <% if (journal.editorInChief.title) { %><%= journal.editorInChief.title %> <% } %><%= journal.editorInChief.name %>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/theme.js"></script>
</body>
</html>
