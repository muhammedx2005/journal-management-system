<%- include('../partials/header') %>

<div class="mb-4 d-flex align-items-center gap-3">
  <span class="profile-avatar"><%= (profileUser.name || "?").charAt(0).toUpperCase() %></span>
  <div>
    <h1 class="h3 mb-1">Profilim</h1>
    <p class="text-muted mb-0"><%= profileUser.name %> <%= profileUser.surname %> &middot; <%= profileUser.email %></p>
  </div>
</div>

<% if (errorMessage) { %>
  <div class="alert alert-danger py-2"><%= errorMessage %></div>
<% } %>
<% if (successMessage) { %>
  <div class="alert alert-success py-2"><%= successMessage %></div>
<% } %>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card mb-4">
      <div class="card-body p-4">
        <h2 class="h5 mb-3"><i class="bi bi-person-lines-fill me-2"></i>Kişisel Bilgiler</h2>
        <form action="/profile" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Ad</label>
              <input type="text" name="name" class="form-control" value="<%= profileUser.name %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Soyad</label>
              <input type="text" name="surname" class="form-control" value="<%= profileUser.surname %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Kurum</label>
              <input type="text" name="institution" class="form-control" value="<%= profileUser.institution || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label">ORCID No</label>
              <input
                type="text"
                name="orcidNo"
                class="form-control"
                value="<%= profileUser.orcid_no || '' %>"
                placeholder="0000-0000-0000-0000"
              />
            </div>
          </div>
          <button type="submit" class="btn btn-primary mt-4">
            <i class="bi bi-check-lg me-1"></i>Bilgileri Kaydet
          </button>
        </form>
      </div>
    </div>

    <div class="card">
      <div class="card-body p-4">
        <h2 class="h5 mb-3"><i class="bi bi-shield-lock me-2"></i>Şifre Değiştir</h2>
        <form action="/profile/password" method="POST">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Mevcut Şifre</label>
              <input type="password" name="currentPassword" class="form-control" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Yeni Şifre</label>
              <input type="password" name="newPassword" class="form-control" required minlength="8" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Yeni Şifre (Tekrar)</label>
              <input type="password" name="newPasswordConfirm" class="form-control" required minlength="8" />
            </div>
          </div>
          <button type="submit" class="btn btn-outline-primary mt-4">
            <i class="bi bi-key me-1"></i>Şifreyi Güncelle
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card">
      <div class="card-body p-4">
        <h2 class="h5 mb-3"><i class="bi bi-info-circle me-2"></i>Hesap Bilgisi</h2>
        <div class="profile-fact">
          <i class="bi bi-person-badge text-primary"></i>
          <span class="text-muted small">Rol</span>
          <span class="ms-auto badge rounded-pill text-bg-secondary"><%= profileUser.role %></span>
        </div>
        <div class="profile-fact">
          <i class="bi bi-calendar3 text-primary"></i>
          <span class="text-muted small">Kayıt Tarihi</span>
          <span class="ms-auto small"><%= new Date(profileUser.created_at).toLocaleDateString("tr-TR") %></span>
        </div>
        <% if (profileUser.is_superadmin) { %>
          <div class="profile-fact">
            <i class="bi bi-shield-lock text-primary"></i>
            <span class="text-muted small">Yetki</span>
            <span class="ms-auto badge rounded-pill badge--published">Süper Admin</span>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
