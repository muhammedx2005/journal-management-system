<%- include('../partials/header') %>

<div class="page-banner p-4 p-md-5 mb-5">
  <div class="page-banner__bg" style="background-image: url('<%= journal.media.guidelinesImage %>');" role="img" aria-label="<%= journal.media.guidelinesImageAlt %>"></div>
  <div class="page-banner__overlay"></div>
  <div>
    <span class="hero-eyebrow mb-2"><i class="bi bi-file-earmark-text"></i>Yazarlara Rehber</span>
    <h1 class="h2 fw-bold mt-3 mb-0">Makale Gönderim Kılavuzu</h1>
  </div>
</div>

<section class="mb-5">
  <p class="text-muted fs-5" style="max-width: 48rem;"><%= journal.authorGuidelines.intro %></p>
</section>

<section class="mb-5">
  <span class="section-eyebrow">Süreç</span>
  <h2 class="h3 mb-4 mt-2">Gönderim ve Değerlendirme Adımları</h2>
  <div class="row g-4">
    <% journal.authorGuidelines.submissionSteps.forEach(function (step, index) { %>
      <div class="col-md-6">
        <div class="card h-100">
          <div class="card-body d-flex gap-3">
            <span class="icon-tile flex-shrink-0"><%= index + 1 %></span>
            <p class="mb-0 small text-muted d-flex align-items-center"><%= step %></p>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<section class="mb-5">
  <div class="row g-5">
    <div class="col-lg-7">
      <span class="section-eyebrow">Format</span>
      <h2 class="h3 mb-4 mt-2">Yazım Kuralları</h2>
      <ul class="list-unstyled d-grid gap-3 mb-0">
        <% journal.authorGuidelines.formattingRules.forEach(function (rule) { %>
          <li class="d-flex align-items-start gap-2">
            <i class="bi bi-check2-square text-primary fs-5 mt-1"></i>
            <span class="text-muted"><%= rule %></span>
          </li>
        <% }) %>
      </ul>
    </div>
    <div class="col-lg-5">
      <div class="card h-100">
        <div class="card-body">
          <span class="icon-tile mb-3"><i class="bi bi-shield-check"></i></span>
          <h3 class="h5">Hakem Değerlendirme Süreci</h3>
          <p class="text-muted small mb-0"><%= journal.authorGuidelines.reviewProcess %></p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="hero-modern p-4 p-md-5 text-center">
  <div class="hero-modern__bg" style="background-image: url('<%= journal.media.heroImage %>');"></div>
  <div class="hero-modern__overlay"></div>
  <div class="py-3">
    <h2 class="h4 mb-3">Hazırsanız makalenizi gönderin</h2>
    <a href="/author/signup" class="btn btn-cta btn-lg">
      <i class="bi bi-send me-1"></i>Yazar Olarak Başvur
    </a>
  </div>
</section>

<%- include('../partials/footer') %>
