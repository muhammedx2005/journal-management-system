<%- include('../partials/header') %>

<div class="mb-4">
  <h1 class="h3 mb-1">Bana Atanan Makaleler</h1>
  <p class="text-muted"><%= journal.name %> dergisi için değerlendirmeniz istenen makaleler.</p>
</div>

<% if (assignments.length === 0) { %>
  <div class="card">
    <div class="card-body text-center text-muted py-5">
      <i class="bi bi-inbox display-6 d-block mb-2"></i>
      Şu anda size atanmış bir makale bulunmuyor.
    </div>
  </div>
<% } else { %>
  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Makale Kodu</th>
            <th>Başlık</th>
            <th>Atanma Tarihi</th>
            <th>Durum</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% assignments.forEach(function (assignment) { %>
            <tr>
              <td class="text-nowrap"><%= assignment.paper_code %></td>
              <td><%= assignment.title %></td>
              <td class="text-nowrap"><%= assignment.assigned_at.toLocaleDateString('tr-TR') %></td>
              <td>
                <% if (assignment.isCompleted) { %>
                  <span class="badge rounded-pill badge--accepted"><i class="bi bi-check-circle me-1"></i>Tamamlandı</span>
                <% } else { %>
                  <span class="badge rounded-pill badge--under_review"><i class="bi bi-hourglass-split me-1"></i>Bekliyor</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="/reviewer/assignments/<%= assignment.assignment_id %>" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-eye me-1"></i>Görüntüle
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>
